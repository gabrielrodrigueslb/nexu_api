NODE_ENV=development
PORT=3333
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexu_next?schema=public"
CORS_ORIGINS="http://localhost:3000"
TRUST_PROXY=0
JWT_ISSUER="nexu-api"
JWT_AUDIENCE="nexu-clients"
JWT_ACCESS_SECRET="troque-esta-chave-por-uma-chave-longa-e-segura-com-mais-de-32-caracteres"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=7
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15
