generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id                  String         @id @default(cuid())
  name                String
  email               String         @unique
  passwordHash        String
  role                String
  sector              String
  accessPresetId      String?
  isActive            Boolean        @default(true)
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  sessionVersion      Int            @default(0)
  lastLoginAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  accessPreset        AccessPreset?  @relation(fields: [accessPresetId], references: [id], onDelete: SetNull)
  modulePermissions   UserModulePermission[]
  actionPermissions   UserActionPermission[]
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]     @relation("ActorAuditLogs")
  createdLeads        Lead[]         @relation("LeadCreator")
  soldLeads           Lead[]         @relation("LeadSeller")
  sdrLeads            Lead[]         @relation("LeadSdr")
  createdTickets      Ticket[]       @relation("TicketCreator")
  assignedTickets     Ticket[]       @relation("TicketAssignee")
  technicalTickets    Ticket[]       @relation("TicketTechnicalAssignee")
  uploadedTicketAttachments TicketAttachment[] @relation("TicketAttachmentUploader")
  leadComments        LeadComment[]
  ticketComments      TicketComment[]
  ticketTasks         TicketTask[]
  indicatorPayments   IndicatorPayment[] @relation("IndicatorPaymentPaidBy")
  createdDevTickets   DevTicket[]        @relation("DevTicketCreator")
  assignedDevTickets  DevTicket[]        @relation("DevTicketAssignee")
  devTicketComments   DevTicketComment[]

  @@index([role, isActive])
  @@index([sector, isActive])
  @@index([accessPresetId])
  @@index([createdAt])
}

model Sector {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, sortOrder])
}

model RefreshToken {
  id                String   @id @default(cuid())
  userId            String
  family            String
  tokenHash         String   @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([family])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String?
  action     String
  entityType String
  entityId   String
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model AccessModule {
  key               String                   @id
  name              String
  description       String?
  parentKey         String?
  path              String?
  scope             String                   @default("MODULE")
  active            Boolean                  @default(true)
  isSystem          Boolean                  @default(true)
  sortOrder         Int                      @default(0)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  parent            AccessModule?            @relation("AccessModuleHierarchy", fields: [parentKey], references: [key], onDelete: SetNull)
  children          AccessModule[]           @relation("AccessModuleHierarchy")
  actions           AccessAction[]
  presetPermissions AccessPresetPermission[]
  userPermissions   UserModulePermission[]
  trashItems        TrashItem[]
  presetActionPermissions AccessPresetActionPermission[]
  userActionPermissions   UserActionPermission[]

  @@index([active, sortOrder])
  @@index([parentKey, active, sortOrder])
}

model AccessPreset {
  id                String                   @id @default(cuid())
  name              String
  slug              String                   @unique
  description       String?
  role              String
  isSystem          Boolean                  @default(false)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  users             User[]
  modulePermissions AccessPresetPermission[]
  actionPermissions AccessPresetActionPermission[]

  @@index([role, isSystem])
  @@index([createdAt])
}

model AccessPresetPermission {
  id          String       @id @default(cuid())
  presetId     String
  moduleKey    String
  accessLevel String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  preset      AccessPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  module      AccessModule @relation(fields: [moduleKey], references: [key], onDelete: Restrict)

  @@unique([presetId, moduleKey])
  @@index([moduleKey, accessLevel])
}

model UserModulePermission {
  id          String       @id @default(cuid())
  userId       String
  moduleKey    String
  accessLevel String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module      AccessModule @relation(fields: [moduleKey], references: [key], onDelete: Restrict)

  @@unique([userId, moduleKey])
  @@index([moduleKey, accessLevel])
}

model AccessAction {
  id          String   @id @default(cuid())
  moduleKey    String
  key         String
  label       String
  description String?
  active      Boolean  @default(true)
  isSystem    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  module      AccessModule @relation(fields: [moduleKey], references: [key], onDelete: Cascade)
  presetPermissions AccessPresetActionPermission[]
  userPermissions   UserActionPermission[]

  @@unique([moduleKey, key])
  @@index([moduleKey, active, sortOrder])
}

model AccessPresetActionPermission {
  id         String   @id @default(cuid())
  presetId    String
  moduleKey   String
  actionKey   String
  allowed    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  preset     AccessPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  module     AccessModule @relation(fields: [moduleKey], references: [key], onDelete: Cascade)
  action     AccessAction @relation(fields: [moduleKey, actionKey], references: [moduleKey, key], onDelete: Cascade)

  @@unique([presetId, moduleKey, actionKey])
  @@index([moduleKey, actionKey, allowed])
}

model UserActionPermission {
  id         String   @id @default(cuid())
  userId      String
  moduleKey   String
  actionKey   String
  allowed    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     AccessModule @relation(fields: [moduleKey], references: [key], onDelete: Cascade)
  action     AccessAction @relation(fields: [moduleKey, actionKey], references: [moduleKey, key], onDelete: Cascade)

  @@unique([userId, moduleKey, actionKey])
  @@index([moduleKey, actionKey, allowed])
}

model TrashItem {
  id          String       @id @default(cuid())
  moduleKey   String
  entityType  String
  entityId    String
  label       String
  payload     String
  deletedById String?
  deletedAt   DateTime     @default(now())
  module      AccessModule @relation(fields: [moduleKey], references: [key], onDelete: Restrict)

  @@index([moduleKey, deletedAt])
  @@index([entityType, entityId])
  @@index([deletedById, deletedAt])
}

model CatalogItem {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  type           String
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  leadSelections LeadCatalogItem[]

  @@unique([type, name])
  @@index([type, active])
}

model Plan {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  description          String?
  features             String?
  restrictions         String?
  setupFeeInCents      Int       @default(0)
  monthlyFeeInCents    Int       @default(0)
  includedAgents       Int       @default(0)
  includedSupervisors  Int       @default(0)
  includedAdmins       Int       @default(0)
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  leads                Lead[]
  tickets              Ticket[]

  @@unique([name])
  @@index([active, createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt])
}

model Origin {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]

  @@index([active, createdAt])
}

model Indicator {
  id           String   @id @default(cuid())
  name         String
  docType      String
  docNumber    String?  @unique
  contact      String?
  email        String?
  percentSetup Int
  bank         String?
  agency       String?
  account      String?
  pixKey       String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leads        Lead[]
  payments     IndicatorPayment[]

  @@index([active, createdAt])
  @@index([name])
}

model CrmFunnel {
  id         String           @id @default(cuid())
  name       String
  slug       String           @unique
  active     Boolean          @default(true)
  isDefault  Boolean          @default(false)
  sortOrder  Int              @default(0)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  stages     CrmFunnelStage[]
  leads      Lead[]

  @@index([active, sortOrder])
  @@index([isDefault, active])
  @@index([name])
}

model CrmFunnelStage {
  id         String      @id @default(cuid())
  funnelId    String
  name       String
  sortOrder  Int         @default(0)
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  funnel     CrmFunnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  leads      Lead[]

  @@unique([funnelId, name])
  @@index([funnelId, active, sortOrder])
}

model Lead {
  id            String            @id @default(cuid())
  company       String
  cnpj          String?
  contact       String?
  email         String?
  phone         String?
  status        String
  funnelId      String?
  stageId       String?
  valueInCents  Int               @default(0)
  paymentMethod String?
  isLite        Boolean           @default(false)
  planId        String?
  wonAt         DateTime?
  lostAt        DateTime?
  notes         String?
  sellerId      String?
  sdrId         String?
  originId      String?
  indicatorId   String?
  createdById   String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  seller        User?             @relation("LeadSeller", fields: [sellerId], references: [id], onDelete: SetNull)
  sdr           User?             @relation("LeadSdr", fields: [sdrId], references: [id], onDelete: SetNull)
  origin        Origin?           @relation(fields: [originId], references: [id], onDelete: SetNull)
  indicator     Indicator?        @relation(fields: [indicatorId], references: [id], onDelete: SetNull)
  plan          Plan?             @relation(fields: [planId], references: [id], onDelete: SetNull)
  funnel        CrmFunnel?        @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  stage         CrmFunnelStage?   @relation(fields: [stageId], references: [id], onDelete: SetNull)
  createdBy     User              @relation("LeadCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tasks         LeadTask[]
  comments      LeadComment[]
  catalogItems  LeadCatalogItem[]
  ticket        Ticket?
  indicatorPayment IndicatorPayment?

  @@index([status, createdAt])
  @@index([sellerId, status])
  @@index([sdrId, status])
  @@index([originId, createdAt])
  @@index([planId, status])
  @@index([funnelId, status])
  @@index([stageId])
  @@index([createdById, createdAt])
  @@index([company])
  @@index([cnpj])
}

model IndicatorPayment {
  id                    String    @id @default(cuid())
  leadId                String    @unique
  indicatorId           String?
  indicatorNameSnapshot String
  leadCompanySnapshot   String
  amountInCents         Int       @default(0)
  status                String    @default("pending")
  dueDate               DateTime?
  paidAt                DateTime?
  notes                 String?
  paidByUserId          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lead                  Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  indicator             Indicator? @relation(fields: [indicatorId], references: [id], onDelete: SetNull)
  paidBy                User?     @relation("IndicatorPaymentPaidBy", fields: [paidByUserId], references: [id], onDelete: SetNull)

  @@index([status, dueDate])
  @@index([indicatorId, status])
  @@index([paidByUserId, paidAt])
}

model FinanceFlowSnapshot {
  id            String   @id @default(cuid())
  referenceDate DateTime?
  importedAt    DateTime @default(now())
  caixaJson     String?
  expensesJson  String   @default("[]")
  revenuesJson  String   @default("[]")
  overdueJson   String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([importedAt])
  @@index([createdAt])
}

model LeadTask {
  id        String   @id @default(cuid())
  leadId     String
  title     String
  type      String
  done      Boolean  @default(false)
  dueDate   DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, done, dueDate])
  @@index([type, done])
}

model LeadComment {
  id           String   @id @default(cuid())
  leadId        String
  authorUserId String
  message      String
  createdAt    DateTime @default(now())
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author       User     @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([leadId, createdAt])
  @@index([authorUserId, createdAt])
}

model LeadCatalogItem {
  id              String      @id @default(cuid())
  leadId          String
  catalogItemId   String
  enabled         Boolean     @default(true)
  setupInCents    Int         @default(0)
  recurringInCents Int        @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  catalogItem     CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)

  @@unique([leadId, catalogItemId])
  @@index([catalogItemId])
  @@index([leadId, enabled])
}

model Ticket {
  id                 String          @id @default(cuid())
  code               String          @unique
  leadId             String?         @unique
  company            String
  cnpj               String?
  contact            String?
  email              String?
  phone              String?
  instance           String?
  plan               String?
  planId             String?
  paymentMethod      String?
  installment        String?
  type               String          @default("novo")
  status             String
  csStatus           String?
  notes              String?
  cancelReason       String?
  setupInCents       Int             @default(0)
  recurringInCents   Int             @default(0)
  createdById        String
  assigneeId         String
  technicalAssigneeId String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  canceledAt         DateTime?
  completedAt        DateTime?
  lead               Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdBy          User            @relation("TicketCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignee           User            @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  technicalAssignee  User?           @relation("TicketTechnicalAssignee", fields: [technicalAssigneeId], references: [id], onDelete: SetNull)
  linkedPlan         Plan?           @relation(fields: [planId], references: [id], onDelete: SetNull)
  tasks              TicketTask[]
  comments           TicketComment[]
  attachments        TicketAttachment[]

  @@index([status, createdAt])
  @@index([assigneeId, status])
  @@index([technicalAssigneeId, status])
  @@index([planId, status])
  @@index([type, status])
  @@index([company])
}

model TicketTask {
  id           String   @id @default(cuid())
  ticketId      String
  assigneeId    String?
  title        String
  done         Boolean  @default(false)
  dueDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  assignee     User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([ticketId, done, dueDate])
  @@index([assigneeId, done])
}

model TicketComment {
  id           String   @id @default(cuid())
  ticketId      String
  authorUserId String
  message      String
  createdAt    DateTime @default(now())
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author       User     @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
  @@index([authorUserId, createdAt])
}

model TicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String
  uploadedById String
  fileName     String
  mimeType     String
  sizeInBytes  Int
  contentBase64 String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("TicketAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
  @@index([uploadedById, createdAt])
}

model DevSprint {
  id        String      @id @default(cuid())
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  closed    Boolean     @default(false)
  closedAt  DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tickets   DevTicket[]

  @@index([closed, startDate])
  @@index([createdAt])
}

model DevTicket {
  id             Int                @id @default(autoincrement())
  proto          String             @unique
  title          String
  category       String
  devType        String
  devStatus      String
  complexity     String             @default("Media")
  score          Int                @default(0)
  totalPts       Int                @default(0)
  createdById    String
  assigneeId     String?
  sprintId       String?
  parentId       Int?
  clientName     String?
  protoExt       String?
  instance       String?
  cnpj           String?
  clientPhone    String?
  description    String
  tagsJson       String             @default("[]")
  criteriaJson   String             @default("{}")
  historyJson    String             @default("[]")
  incident       Boolean            @default(false)
  compliment     Boolean            @default(false)
  docDone        Boolean            @default(false)
  prodBug        Boolean            @default(false)
  reopened       Boolean            @default(false)
  criticalBug    Boolean            @default(false)
  createdAt      DateTime           @default(now())
  startDate      DateTime?
  deadline       DateTime?
  resolvedAt     DateTime?
  updatedAt      DateTime           @updatedAt
  createdBy      User               @relation("DevTicketCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignee       User?              @relation("DevTicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  sprint         DevSprint?         @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  parent         DevTicket?         @relation("DevTicketParent", fields: [parentId], references: [id], onDelete: SetNull)
  children       DevTicket[]        @relation("DevTicketParent")
  comments       DevTicketComment[]

  @@index([devStatus, createdAt])
  @@index([devType, devStatus])
  @@index([assigneeId, devStatus])
  @@index([sprintId, devStatus])
  @@index([resolvedAt])
}

model DevTicketComment {
  id           String    @id @default(cuid())
  ticketId      Int
  authorUserId String
  message      String
  createdAt    DateTime  @default(now())
  ticket       DevTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author       User      @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt])
  @@index([authorUserId, createdAt])
}
